{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "bin/yt-dlp", "sidecar": true, "args": true },
        { "name": "bin/ffmpeg", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "bin/yt-dlp", "sidecar": true, "args": true },
        { "name": "bin/ffmpeg", "sidecar": true, "args": true }
      ]
    },
    { "identifier": "fs:allow-read-dir", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-read-file", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-write-file", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-exists", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-mkdir", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-rename", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-remove", "allow": [{ "path": "**" }] }
  ]
}